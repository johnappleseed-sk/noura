# Backend base URL for server + browser calls.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional override for server-only fetch calls (build-time, SSR).
API_BASE_URL=http://localhost:8080

# Optional explicit commerce/inventory endpoints (defaults to NEXT_PUBLIC_API_BASE_URL if unset).
NEXT_PUBLIC_COMMERCE_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_INVENTORY_API_BASE_URL=http://localhost:8080/api/inventory/v1
